# Reco service config
PORT=8080
MONGODB_URI=mongodb://localhost:27017/kfc
BACKEND_URL=http://localhost:3000

# L5 LLM rerank + copywriting (optional — falls back to templates if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# LLM provider switch (default remains OpenAI, so existing deployments are unchanged).
# To opt in later: set LLM_PROVIDER=greennode and provide GREENNODE_API_KEY.
LLM_PROVIDER=openai
GREENNODE_API_KEY=
GREENNODE_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
GREENNODE_MODEL=minimax/minimax-m2.5

# Voice-note transcription. AAC from Zalo is converted to WAV with ffmpeg.
# Falls back to OPENAI_API_KEY when OPENAI_TRANSCRIBE_API_KEY is blank.
OPENAI_TRANSCRIBE_API_KEY=
OPENAI_TRANSCRIBE_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
AUDIO_MAX_BYTES=20971520
AUDIO_MAX_SECONDS=300

# P4 chat memory: new conversation after 10 minutes idle; hard LLM history cap.
CHAT_IDLE_TIMEOUT_SECONDS=600
CHAT_CONTEXT_MESSAGES=20

# L3 vector search (optional — falls back to heuristics if unavailable)
RECO_USE_EMBEDDINGS=false
QDRANT_URL=http://localhost:6333
RAG_COLLECTION=kfc_menu
RAG_DENSE_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Mining params
MIN_SUPPORT=0.01
MIN_CONFIDENCE=0.15

# ── P4 Zalo OA transport (optional — only needed to run the Zalo webhook) ───────
# From the Zalo App console (App > Settings) and the OA. Leave blank to disable.
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_SECRET=
# Domain-verification meta-tag content (Zalo App > Official Account > Verify domain)
ZALO_VERIFY_META=
# Seed OA tokens from a completed OAuth consent — auto-refreshed + persisted after.
ZALO_ACCESS_TOKEN=
ZALO_REFRESH_TOKEN=
# Endpoints (override only if Zalo revs the API)
ZALO_OAUTH_URL=https://oauth.zaloapp.com/v4/oa/access_token
ZALO_OA_API_URL=https://openapi.zalo.me
# Comma-separated trusted suffixes for signed Zalo audio attachment URLs.
ZALO_AUDIO_HOST_SUFFIXES=zdn.vn
