# Reco service config
PORT=8080
MONGODB_URI=mongodb://localhost:27017/kfc
BACKEND_URL=http://localhost:3000

# L5 LLM rerank + copywriting (optional — falls back to templates if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# L3 vector search (optional — falls back to heuristics if unavailable)
RECO_USE_EMBEDDINGS=false
QDRANT_URL=http://localhost:6333
RAG_COLLECTION=kfc_menu
RAG_DENSE_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Mining params
MIN_SUPPORT=0.01
MIN_CONFIDENCE=0.15

# ── P4 Zalo OA transport (optional — only needed to run the Zalo webhook) ───────
# From the Zalo App console (App > Settings) and the OA. Leave blank to disable.
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_SECRET=
# Domain-verification meta-tag content (Zalo App > Official Account > Verify domain)
ZALO_VERIFY_META=
# Seed OA tokens from a completed OAuth consent — auto-refreshed + persisted after.
ZALO_ACCESS_TOKEN=
ZALO_REFRESH_TOKEN=
# Endpoints (override only if Zalo revs the API)
ZALO_OAUTH_URL=https://oauth.zaloapp.com/v4/oa/access_token
ZALO_OA_API_URL=https://openapi.zalo.me
